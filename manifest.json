{
  "manifest_version": 2,
  "name": "Zotero Assistant",
  "version": "0.1.2",
  "description": "Zotero 9 desktop assistant with task harness, button approvals, audit log, and reversible library actions.",
  "icons": {
    "16": "icons/zotero-assistant-icon-16.png",
    "32": "icons/zotero-assistant-icon-32.png",
    "48": "icons/zotero-assistant-icon-48.png",
    "96": "icons/zotero-assistant-icon-96.png",
    "128": "icons/zotero-assistant-icon-128.png"
  },
  "homepage_url": "https://github.com/origin652/zotero-assistant",
  "applications": {
    "zotero": {
      "id": "zotero-assistant@origin652.github.io",
      "update_url": "https://github.com/origin652/zotero-assistant/releases/latest/download/updates.json",
      "strict_min_version": "9.0",
      "strict_max_version": "9.0.*"
    }
  }
}
